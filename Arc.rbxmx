				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXABFA47CD838048598D69A23959387D8C">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Atlas = {}

function Atlas.create(class: string, properties: {[string]: any})
	local instance: Instance = Instance.new(class)
	local parent: Instance? = nil

	for k,v in (properties or {}) do
		if k == `Parent` then 
			parent = v 
			continue 
		elseif k == `Children` then
			for _,child in (v) do
				child.Parent = instance
			end
			continue
		end
		instance[k] = v
	end

	if parent then instance.Parent = parent end
	return instance
end

return Atlas]]></ProtectedString>
